<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="app"/>
    <springProperty scope="context" name="lokiUrl" source="observability.loki.url" defaultValue=""/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{36} traceId=%X{traceId:-} spanId=%X{spanId:-} - %msg%n</pattern>
        </encoder>
    </appender>

    <if condition='!property("lokiUrl").isEmpty()'>
        <then>
            <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
                <http>
                    <url>${lokiUrl}</url>
                </http>
                <labels>
                    app = ${appName}
                    level = %level
                </labels>
                <structuredMetadata>
                    traceId = %X{traceId}
                    spanId = %X{spanId}
                    logger = %logger
                    thread = %thread
                </structuredMetadata>
                <message>
                    <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level %logger{36} traceId=%X{traceId:-} spanId=%X{spanId:-} - %msg</pattern>
                </message>
            </appender>
        </then>
    </if>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <if condition='!property("lokiUrl").isEmpty()'>
            <then>
                <appender-ref ref="LOKI"/>
            </then>
        </if>
    </root>
</configuration>
